# ============================================================
# OmniClient AI Agent Platform â€” Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Get a FREE OpenRouter API key at: https://openrouter.ai/keys

# --- OpenRouter AI ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=cohere/north-mini-code:free
FALLBACK_MODEL=qwen/qwen3-coder:free
ENABLE_REASONING=true

# --- Application ---
APP_NAME=OmniClient AI
APP_PORT=8001
DEBUG=true

# --- Database ---
DATABASE_URL=sqlite:///./omniclient.db

# --- Memory ---
MAX_MEMORY_ENTRIES=50
MEMORY_SUMMARY_THRESHOLD=10

# --- Search ---
ENABLE_DEEP_SEARCH=true
MAX_SEARCH_RESULTS=5


