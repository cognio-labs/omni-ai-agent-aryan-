# ============================================================
# OmniClient AI Agent Platform â€” Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Get a FREE OpenRouter API key at: https://openrouter.ai/keys

# --- OpenRouter AI ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=cohere/north-mini-code:free
FALLBACK_MODEL=qwen/qwen3-coder:free
ENABLE_REASONING=true

# --- Application ---
APP_NAME=OmniClient AI
APP_PORT=8001
DEBUG=true

# --- Database ---
DATABASE_URL=sqlite:///./omniclient.db

# --- Memory ---
MAX_MEMORY_ENTRIES=50
MEMORY_SUMMARY_THRESHOLD=10

# --- Search ---
ENABLE_DEEP_SEARCH=true
MAX_SEARCH_RESULTS=5



# --- E2B Sandbox ---
E2B_API_KEY=your_e2b_api_key_here
E2B_TEMPLATE_ID=

# --- Stripe Billing ---
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_PRO=price_your_pro_price_id
STRIPE_PRICE_ID_ENTERPRISE=price_your_enterprise_price_id
FREE_TIER_MESSAGE_LIMIT=20
